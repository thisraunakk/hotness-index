<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Hotness index</title>
<style>
  * { box-sizing: border-box; }
  :root {
    --bg: #15130f;
    --surface: #1e1b16;
    --surface-2: #262219;
    --border: #322d24;
    --text: #f3eee4;
    --text-secondary: #b8af9f;
    --text-muted: #8a8170;
    --cold: #5b7fa6;
    --hot: #d8432a;
    --mono: 'SF Mono', Menlo, Consolas, 'Roboto Mono', monospace;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    display: flex;
    justify-content: center;
    padding: 40px 16px;
  }
  .card { width: 100%; max-width: 460px; }
  .eyebrow { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin: 0 0 6px; }
  h1 { font-size: 23px; font-weight: 600; margin: 0 0 8px; }
  .sub { font-size: 14px; color: var(--text-secondary); margin: 0 0 28px; line-height: 1.55; }

  .readout { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 22px; }
  .readout-row { display: flex; align-items: baseline; gap: 12px; }
  .readout-num { font-family: var(--mono); font-size: 54px; font-weight: 600; line-height: 1; letter-spacing: -0.02em; }
  .readout-band { font-size: 15px; color: var(--text-secondary); font-weight: 500; }
  .readout-feels { font-size: 13px; color: var(--text-muted); margin: 8px 0 0; font-family: var(--mono); }

  .gauge-wrap { margin: 22px 0 6px; }
  .gauge-track { position: relative; height: 10px; border-radius: 6px; background: linear-gradient(to right, var(--cold), var(--surface-2) 50%, var(--hot)); }
  .gauge-marker { position: absolute; top: -5px; width: 3px; height: 20px; background: var(--text); border-radius: 2px; transform: translateX(-50%); transition: left 0.15s ease; }
  .gauge-scale { display: flex; justify-content: space-between; font-size: 11px; color: var(--text-muted); margin-top: 6px; font-family: var(--mono); }

  .presets { display: flex; gap: 8px; margin-bottom: 26px; flex-wrap: wrap; }
  .preset-btn { flex: 1; min-width: 120px; background: var(--surface); border: 1px solid var(--border); color: var(--text-secondary); font-size: 12.5px; padding: 9px 8px; border-radius: 9px; cursor: pointer; font-family: var(--sans); }
  .preset-btn:hover { border-color: var(--text-muted); color: var(--text); }

  .field { margin-bottom: 18px; }
  .field-label-row { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px; }
  .field-label { color: var(--text-secondary); }
  .field-value { font-family: var(--mono); color: var(--text); }
  input[type="range"] { width: 100%; --webkit-appearance: none; height: 4px; background: var(--surface-2); border-radius: 2px; outline: none; }
  input[type="range"]::-webkit-slider-thumb { --webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%; background: var(--text); cursor: pointer; border: 2px solid var(--bg); }
  input[type="range"]::-moz-range-thumb { width: 16px; height: 16px; border-radius: 50%; background: var(--text); cursor: pointer; border: 2px solid var(--bg); }

  .toggle-row { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-secondary); cursor: pointer; margin-bottom: 4px; }
  .toggle-row input { width: 16px; height: 16px; accent-color: var(--hot); }

  details { margin-top: 10px; border-top: 1px solid var(--border); padding-top: 16px; }
  summary { font-size: 13px; color: var(--text-muted); cursor: pointer; }
  details[open] summary { color: var(--text-secondary); }
  .calib-fields { margin-top: 16px; }

  .formula { margin-top: 28px; border-top: 1px solid var(--border); padding-top: 16px; font-size: 12px; color: var(--text-muted); line-height: 1.7; font-family: var(--mono); }
  .formula-label { font-family: var(--sans); color: var(--text-secondary); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }

  /* --- additions below: mode toggle, location line, disabled inputs, credit footer --- */
  .mode-toggle { display: flex; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 4px; margin-bottom: 24px; }
  .mode-btn { flex: 1; background: transparent; border: none; color: var(--text-muted); font-size: 13px; padding: 8px 10px; border-radius: 8px; cursor: pointer; font-family: var(--sans); }
  .mode-btn.active { background: var(--surface-2); color: var(--text); }

  .readout-location { font-size: 13px; color: var(--text-muted); margin: 4px 0 0; font-family: var(--sans); }

  input[type="range"]:disabled { opacity: 0.45; cursor: not-allowed; }
  .toggle-row input:disabled { opacity: 0.45; cursor: not-allowed; }

  .credit { margin-top: 32px; padding-top: 16px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-muted); text-align: center; }
  .credit a { color: var(--text-secondary); text-decoration: none; border-bottom: 1px dotted var(--text-muted); }
  .credit a:hover { color: var(--text); }
</style>
</head>
<body>
<div class="card">
  <p class="eyebrow">A personal instrument</p>
  <h1>Hotness index</h1>
  <p class="sub">Not Celsius, not Fahrenheit — how it actually feels, on a scale where 5 means "fine."</p>

  <div class="mode-toggle">
    <button class="mode-btn active" id="mode-live" type="button">Live at your location</button>
    <button class="mode-btn" id="mode-manual" type="button">Try it yourself</button>
  </div>

  <div class="readout">
    <div class="readout-row">
      <span class="readout-num" id="result-num">5.0</span>
      <span class="readout-band" id="band-label">Neutral</span>
    </div>
    <p class="readout-feels">feels like <span id="feels-out">20.0°C</span></p>
    <p class="readout-location" id="location-line" style="display: none;">in <span id="location-name">locating…</span></p>
    <div class="gauge-wrap">
      <div class="gauge-track">
        <div class="gauge-marker" id="marker"></div>
      </div>
      <div class="gauge-scale"><span>0 cold</span><span>5 neutral</span><span>10 hot</span></div>
    </div>
  </div>

  <div class="presets">
    <button class="preset-btn" onclick="setPreset(33,55,8,true)">UK heatwave</button>
    <button class="preset-btn" onclick="setPreset(33,25,12,false)">Dry heat, Kathmandu-style</button>
    <button class="preset-btn" onclick="setPreset(22,40,5,false)">Mild day</button>
  </div>

  <div class="field">
    <div class="field-label-row"><span class="field-label">Temperature</span><span class="field-value" id="temp-out"><%= defaults.temp %>°C</span></div>
    <input type="range" min="-10" max="45" step="1" value="<%= defaults.temp %>" id="temp">
  </div>
  <div class="field">
    <div class="field-label-row"><span class="field-label">Humidity</span><span class="field-value" id="hum-out"><%= defaults.humidity %>%</span></div>
    <input type="range" min="0" max="100" step="1" value="<%= defaults.humidity %>" id="hum">
  </div>
  <div class="field">
    <div class="field-label-row"><span class="field-label">Wind</span><span class="field-value" id="wind-out"><%= defaults.wind %> km/h</span></div>
    <input type="range" min="0" max="50" step="1" value="<%= defaults.wind %>" id="wind">
  </div>
  <label class="toggle-row"><input type="checkbox" id="sun" <%= defaults.sun ? 'checked' : '' %>> Standing in direct sun</label>

  <details>
    <summary>Personal calibration</summary>
    <div class="calib-fields">
      <div class="field">
        <div class="field-label-row"><span class="field-label">Your neutral point</span><span class="field-value" id="neutral-out"><%= defaults.neutral %>°C</span></div>
        <input type="range" min="10" max="28" step="1" value="<%= defaults.neutral %>" id="neutral">
      </div>
      <div class="field">
        <div class="field-label-row"><span class="field-label">Sensitivity</span><span class="field-value" id="sens-out"><%= defaults.sensitivity %></span></div>
        <input type="range" min="0.06" max="0.18" step="0.01" value="<%= defaults.sensitivity %>" id="sens">
      </div>
    </div>
  </details>

  <div class="formula">
    <p class="formula-label">The formula</p>
    e&nbsp;=&nbsp;(RH/100)&middot;6.105&middot;exp(17.27T/(237.7+T))<br>
    AT&nbsp;=&nbsp;T&nbsp;+&nbsp;0.33e&nbsp;&minus;&nbsp;0.7w&nbsp;&minus;&nbsp;4&nbsp;(+3 in direct sun)<br>
    H&nbsp;=&nbsp;10&nbsp;/&nbsp;(1&nbsp;+&nbsp;e^(&minus;k(AT&minus;N)))
  </div>

  <footer class="credit">
    Made by <a href="<%= author.github %>" target="_blank" rel="noopener noreferrer"><%= author.name %></a>
  </footer>
</div>

<script>
function vaporPressure(T, RH) { return (RH / 100) * 6.105 * Math.exp(17.27 * T / (237.7 + T)); }
function band(H) {
  if (H < 1) return 'Freezing';
  if (H < 3) return 'Cold';
  if (H < 4.5) return 'Cool';
  if (H < 5.5) return 'Neutral';
  if (H < 7) return 'Warm';
  if (H < 8.5) return 'Hot';
  return 'Scorching';
}
var tempEl = document.getElementById('temp');
var humEl = document.getElementById('hum');
var windEl = document.getElementById('wind');
var sunEl = document.getElementById('sun');
var neutralEl = document.getElementById('neutral');
var sensEl = document.getElementById('sens');
var tempOut = document.getElementById('temp-out');
var humOut = document.getElementById('hum-out');
var windOut = document.getElementById('wind-out');
var neutralOut = document.getElementById('neutral-out');
var sensOut = document.getElementById('sens-out');
var resultNum = document.getElementById('result-num');
var bandLabel = document.getElementById('band-label');
var feelsOut = document.getElementById('feels-out');
var marker = document.getElementById('marker');

function calc() {
  var T = parseFloat(tempEl.value);
  var RH = parseFloat(humEl.value);
  var windKmh = parseFloat(windEl.value);
  var sun = sunEl.checked;
  var neutral = parseFloat(neutralEl.value);
  var k = parseFloat(sensEl.value);
  var windMs = windKmh / 3.6;
  var e = vaporPressure(T, RH);
  var AT = T + 0.33 * e - 0.7 * windMs - 4.0;
  if (sun) { AT += 3; }
  var H = 10 / (1 + Math.exp(-k * (AT - neutral)));

  tempOut.textContent = T.toFixed(0) + '°C';
  humOut.textContent = RH.toFixed(0) + '%';
  windOut.textContent = windKmh.toFixed(0) + ' km/h';
  neutralOut.textContent = neutral.toFixed(0) + '°C';
  sensOut.textContent = k.toFixed(2);
  resultNum.textContent = H.toFixed(1);
  feelsOut.textContent = AT.toFixed(1) + '°C';
  bandLabel.textContent = band(H);
  marker.style.left = Math.min(100, Math.max(0, H / 10 * 100)) + '%';
}

function setPreset(t, h, w, s) {
  tempEl.value = t; humEl.value = h; windEl.value = w; sunEl.checked = s; calc();
}

[tempEl, humEl, windEl, sunEl, neutralEl, sensEl].forEach(function (el) {
  el.addEventListener('input', calc);
});
calc();

/* --- live / manual mode handling --- */
var modeLiveBtn = document.getElementById('mode-live');
var modeManualBtn = document.getElementById('mode-manual');
var locationLine = document.getElementById('location-line');
var locationNameEl = document.getElementById('location-name');
var presetsEl = document.querySelector('.presets');
var manualInputs = [tempEl, humEl, windEl, sunEl];

function setManualDisabled(disabled) {
  manualInputs.forEach(function (el) { el.disabled = disabled; });
}

function showLiveUI(show) {
  presetsEl.style.display = show ? 'none' : 'flex';
  locationLine.style.display = show ? 'block' : 'none';
}

function setMode(mode) {
  modeLiveBtn.classList.toggle('active', mode === 'live');
  modeManualBtn.classList.toggle('active', mode === 'manual');
  if (mode === 'live') {
    setManualDisabled(true);
    showLiveUI(true);
    fetchLiveData();
  } else {
    setManualDisabled(false);
    showLiveUI(false);
  }
}

function fetchLiveData() {
  locationNameEl.textContent = 'locating…';
  if (!navigator.geolocation) {
    locationNameEl.textContent = 'location not supported on this browser — try "Try it yourself"';
    return;
  }
  navigator.geolocation.getCurrentPosition(function (pos) {
    var lat = pos.coords.latitude;
    var lon = pos.coords.longitude;
    locationNameEl.textContent = 'fetching weather…';
    fetch('/api/live', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ latitude: lat, longitude: lon })
    })
      .then(function (r) {
        if (!r.ok) throw new Error('request failed');
        return r.json();
      })
      .then(function (data) {
        tempEl.value = Math.round(data.temperature);
        humEl.value = Math.round(data.humidity);
        windEl.value = Math.round(data.wind);
        sunEl.checked = !!data.sun;
        locationNameEl.textContent = data.locationName;
        calc();
      })
      .catch(function () {
        locationNameEl.textContent = 'could not fetch live weather — try "Try it yourself"';
      });
  }, function () {
    locationNameEl.textContent = 'location permission denied — try "Try it yourself"';
  });
}

modeLiveBtn.addEventListener('click', function () { setMode('live'); });
modeManualBtn.addEventListener('click', function () { setMode('manual'); });

setMode('live');
</script>
</body>
</html>